<?php

/**
 * @file
 * Install, update and uninstall functions for the OpenRouter Provider module.
 */

/**
 * Implements hook_install().
 */
function ai_provider_openrouter_install(): void {
  // Grant permissions to administrator role if it exists.
  $role = \Drupal::entityTypeManager()->getStorage('user_role')->load('administrator');
  if ($role) {
    $role->grantPermission('administer ai providers');
    $role->grantPermission('use ai provider openrouter');
    $role->save();
  }
}
